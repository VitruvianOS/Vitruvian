# PAM stack for the Vitruvian desktop session.
# Called by janus at boot to open a real logind session for the desktop
# user (autologin — no password prompt). Anything the login binary would
# normally run is delegated here so session-stage servers see the same
# environment (HOME, XDG_RUNTIME_DIR, LANG, umask, ulimits) as any other
# Linux login.

auth       required     pam_permit.so
account    required     pam_permit.so
password   required     pam_permit.so

session    optional     pam_loginuid.so
session    optional     pam_env.so
session    required     pam_limits.so
session    optional     pam_umask.so
session    optional     pam_systemd.so
