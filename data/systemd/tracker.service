[Unit]
ConditionPathExists=!/var/lib/vos/greeter-enabled
Description=Vitruvian Tracker (file manager)
After=janus.service deskbar.service
Requires=janus.service

[Service]
Type=forking
PIDFile=/run/vos/Tracker.pid
ExecStart=/system/servers/janus_launch Tracker
StandardOutput=append:/var/log/tracker.log
StandardError=append:/var/log/tracker.log
Restart=no

[Install]
WantedBy=graphical.target
