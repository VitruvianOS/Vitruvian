#!/bin/sh

# Base directories

mkdir -p /system/add-ons/
mkdir -p /system/apps/
mkdir -p /system/data/
mkdir -p /system/demos/
mkdir -p /system/develop/
mkdir -p /system/documentation/
mkdir -p /system/preferences/
mkdir -p /system/servers/
mkdir -p /system/settings/

ln -sf /bin /system/bin
# /system/lib MUST become a symlink, not a real dir. `ln -sf SRC DST` when
# DST is an existing dir creates DST/<basename SRC> inside it (silent
# trap). Anything CPack-installed to /system/lib/ has already moved to
# /lib by the time we get here, so it's safe to wipe.
rm -rf /system/lib
ln -sf /lib /system/lib
ln -sf /tmp /system/cache
ln -sf /var /system/var

# Per-user Desktop/Home and Desktop/System symlinks are created on first
# login by /system/boot/first_login/00-desktop-shortcuts, not here.

mkdir -p /etc/skel/config/settings/deskbar/menu/

mkdir -p /system/data/deskbar/menu/
mkdir -p /system/data/deskbar/menu/Applications/
mkdir -p "/system/data/deskbar/menu/Desktop applets/"
mkdir -p /system/data/deskbar/menu/Demos/
mkdir -p /system/data/deskbar/menu/Preferences/


# Boot dirs. The trash dir is NOT pre-created here — Vitruvian uses the
# XDG Trash spec layout ($HOME/.local/share/Trash/{files,info}), which
# Tracker provisions on demand via FSGetTrashDir. The on-Desktop Trash
# icon is a synthetic pose injected by BPoseView::CreateTrashPose.

mkdir -p /system/boot/post_install/
mkdir -p /system/boot/first_login/
mkdir -p /system/settings/etc/profile.d/

mkdir -p "/etc/skel/config/settings/Tracker/Tracker New Templates"
mkdir -p /etc/skel/config/settings/printers/Preview
mkdir -p "/etc/skel/config/settings/printers/Save as PDF"

# BeOS-format xattr helpers using setfattr.
#
# addattr (the Haiku tool) is NOT used here because it loads libroot2 which
# requires nexus IPC — unavailable when postinst runs on the host during
# mkiso package installation.
#
# Format: [type:uint32 LE][data bytes]
# Type codes (four-cc stored as little-endian uint32 on x86):
#   B_STRING_TYPE      = 'CSTR' = 0x43535452  LE bytes: 52 54 53 43
#   B_MIME_STRING_TYPE = 'MIMS' = 0x4d494d53  LE bytes: 53 4d 49 4d
#
# beos_string NAME VALUE PATH  — writes B_STRING_TYPE xattr
# beos_mime   NAME VALUE PATH  — writes B_MIME_STRING_TYPE xattr

beos_string() {
	local name="$1" value="$2" target="$3"
	# B_STRING_TYPE LE prefix + value bytes (no null; setfattr adds none,
	# fs_read_attr only reads dataSize = attrSize - 4 bytes)
	local hex
	hex="52545343$(printf '%s' "$value" | od -A n -t x1 | tr -d ' \n')00"
	setfattr -n "user.beos.${name}" --value="0x${hex}" "${target}"
}

beos_mime() {
	local name="$1" value="$2" target="$3"
	# B_MIME_STRING_TYPE LE prefix
	local hex
	hex="534d494d$(printf '%s' "$value" | od -A n -t x1 | tr -d ' \n')00"
	setfattr -n "user.beos.${name}" --value="0x${hex}" "${target}"
}

# B_UINT32_TYPE = 'UINT' = 0x554e4954, LE bytes 54 49 4e 55.
# Value: little-endian uint32 == 1.
beos_hidden() {
	local target="$1"
	[ -e "$target" ] || return 0
	setfattr -n "user.beos.SYS:HIDDEN" --value="0x54494e5501000000" "${target}" 2>/dev/null || true
}

# Directory identity attributes (SYS:NAME)
# Tracker reads these to assign special folder icons.

beos_string SYS:NAME "x-vnd.Haiku-libtracker:B_SYSTEM_DIRECTORY:system" /system
beos_string SYS:NAME "x-vnd.Haiku-libtracker:B_USER_DIRECTORY:home" /home
# B_DESKTOP_DIRECTORY xattr is stamped per-user at first login (there is
# no shared /home/Desktop). B_USER_CONFIG_DIRECTORY rides skel via cp -a.
beos_string SYS:NAME "x-vnd.Haiku-libtracker:B_USER_CONFIG_DIRECTORY:config" /etc/skel/config
beos_string SYS:NAME "x-vnd.Haiku-libtracker:B_APPS_DIRECTORY:apps" /system/apps
beos_string SYS:NAME "x-vnd.Haiku-libtracker:B_PREFERENCES_DIRECTORY:preferences" /system/preferences
beos_string SYS:NAME "x-vnd.Haiku-libtracker:B_SYSTEM_DEVELOP_DIRECTORY:develop" /system/develop
beos_string SYS:NAME "x-vnd.Be-TSKB:B_USER_DESKBAR_DIRECTORY/Applications:Applications" /system/data/deskbar/menu/Applications
beos_string SYS:NAME "x-vnd.Be-TSKB:B_USER_DESKBAR_DIRECTORY/Demos:Demos" /system/data/deskbar/menu/Demos
beos_string SYS:NAME "x-vnd.Be-TSKB:B_USER_DESKBAR_DIRECTORY/Preferences:Preferences" /system/data/deskbar/menu/Preferences
beos_string SYS:NAME "x-vnd.Be-TSKB:B_USER_DESKBAR_DIRECTORY/Desktop applets:Desktop applets" "/system/data/deskbar/menu/Desktop applets"
beos_string SYS:NAME "x-vnd.Haiku-libtracker:B_USER_SETTINGS_DIRECTORY/Tracker/Tracker New Templates:Tracker New Templates" "/etc/skel/config/settings/Tracker/Tracker New Templates"

# Hide Linux-userland root dirs; /boot /system /home /dev /tmp stay visible.
for _p in /bin /sbin /lib /lib32 /lib64 /libx32 /etc /proc /sys /run \
		/usr /var /mnt /media /opt /srv /root /lost+found /initrd.img \
		/initrd.img.old /vmlinuz /vmlinuz.old /localdeb; do
	beos_hidden "$_p"
done

# Deskbar virtual directory descriptor
# Setting this MIME type makes Model::IsVirtualDirectory() return true, enabling
# VirtualDirectoryEntryList to aggregate the three menu directories listed in the file.
beos_mime BEOS:TYPE "application/x-vnd.haiku-virtual-directory" /system/data/deskbar/menu_entries

# Printer directory attributes (identity + settings read by the print server)

beos_mime BEOS:TYPE "application/x-vnd.Be.printer" /etc/skel/config/settings/printers/Preview
beos_string "Printer Name" "Preview" /etc/skel/config/settings/printers/Preview
beos_string "Driver Name" "Preview" /etc/skel/config/settings/printers/Preview
beos_string "transport" "" /etc/skel/config/settings/printers/Preview
beos_string "transport_address" "" /etc/skel/config/settings/printers/Preview
beos_string "connection" "Local" /etc/skel/config/settings/printers/Preview
beos_string "state" "free" /etc/skel/config/settings/printers/Preview

beos_mime BEOS:TYPE "application/x-vnd.Be.printer" "/etc/skel/config/settings/printers/Save as PDF"
beos_string "Printer Name" "Save as PDF" "/etc/skel/config/settings/printers/Save as PDF"
beos_string "Driver Name" "PDF Writer" "/etc/skel/config/settings/printers/Save as PDF"
beos_string "transport" "Print To File" "/etc/skel/config/settings/printers/Save as PDF"
beos_string "transport_address" "" "/etc/skel/config/settings/printers/Save as PDF"
beos_string "connection" "Local" "/etc/skel/config/settings/printers/Save as PDF"
beos_string "state" "free" "/etc/skel/config/settings/printers/Save as PDF"

# Tracker New Templates — extract files+xattrs into the user template dir.
# Must run before the beos_mime calls below, which stamp MIME types onto
# these template files.
if [ -f /usr/share/vos/templates_attrs.tar ]; then
    mkdir -p "/etc/skel/config/settings/Tracker/Tracker New Templates"
    tar --xattrs -xf /usr/share/vos/templates_attrs.tar \
        -C "/etc/skel/config/settings/Tracker/Tracker New Templates"
fi

# MIME type attributes for Tracker New Templates
# (enables Tracker's File > New menu to create the right file type)
beos_mime BEOS:TYPE "text/plain" "/etc/skel/config/settings/Tracker/Tracker New Templates/text file"
beos_mime BEOS:TYPE "text/x-source-code" "/etc/skel/config/settings/Tracker/Tracker New Templates/C++ source"
beos_mime BEOS:TYPE "text/x-source-code" "/etc/skel/config/settings/Tracker/Tracker New Templates/C++ header"

# Source Vitruvian profile from bash login shells (makes Terminal show the
# welcome message and Vitruvian environment setup)

cat > /etc/profile.d/vitruvian.sh << 'VITRUVIAN_PROFILE_EOF'
# Guard against recursive sourcing: Vitruvian's profile itself sources
# /etc/profile.d/*.sh, which would re-enter this script and cause an
# infinite loop printing "Welcome to Vitruvian" on every login.
if [ -z "$_VOS_PROFILE_SOURCED" ] && [ -f /system/settings/etc/profile ]; then
    export _VOS_PROFILE_SOURCED=1
    . /system/settings/etc/profile
fi
VITRUVIAN_PROFILE_EOF

# MIME database — install with xattrs preserved
# mime_db.tar is a tarball of the mime_db/ directory tree with BeOS xattrs
# (user.beos.*) captured via tar --xattrs during the build. CPack cannot
# preserve xattrs in install(DIRECTORY), so we extract here instead.
mkdir -p /system/data
tar --xattrs -xf /usr/share/vos/mime_db.tar -C /system/data/

# App binary xattrs — restore BeOS attrs to installed binaries.
# apps_attrs.tar contains zero-byte placeholder files at the install paths,
# carrying user.beos.* xattrs written by resattr -O during build.
# We extract to a temp dir and apply attrs to the real installed binaries.
if [ -f /usr/share/vos/apps_attrs.tar ]; then
    _tmp=$(mktemp -d)
    tar --xattrs -xf /usr/share/vos/apps_attrs.tar -C "$_tmp"
    find "$_tmp" -type f | while IFS= read -r _src; do
        _dst="/${_src#$_tmp/}"
        [ -f "$_dst" ] || continue
        getfattr -d -m user.beos -e hex "$_src" 2>/dev/null \
            | sed "s|${_src#/}|${_dst#/}|g" \
            | setfattr --restore - 2>/dev/null || true
    done
    rm -rf "$_tmp"
fi

# Enable system services

systemctl enable janus.service registrar.service app_server.service input_server.service mount_server.service notification_server.service deskbar.service tracker.service userbootscript@vitruvio.service

# TTY-intermediate scaffolding (dormant). The vos-session user unit and
# profile.d hook are installed but only wire in when the operator runs
# `systemctl --user enable vos-session` — see phase3-login.md Stage A.
install -m 0644 -D /usr/share/vos/systemd/vos-session.service \
	/etc/systemd/user/vos-session.service 2>/dev/null || true
install -m 0644 -D /usr/share/vos/profile.d/vos-session.sh \
	/etc/profile.d/vos-session.sh 2>/dev/null || true

# vos_login: pre-auth graphical uid (greeter + FirstBootPrompt +
# live-media Installer). No shell, no home content — janus supplies
# everything needed via env + /var/lib/vos_login runtime dir.
# Membership: video (DRM), input (evdev fallback), tty (VT switching for
# kill+restart), vitruvio (nexus IPC access — same group that owns
# /dev/nexus). See phase3-login.md Stage C.
if ! getent passwd vos_login >/dev/null; then
	useradd --system --no-create-home \
		--home-dir /var/lib/vos_login \
		--shell /usr/sbin/nologin \
		--comment "Vitruvian pre-auth graphical uid" \
		vos_login || true
fi
for _g in video input tty vitruvio; do
	getent group "$_g" >/dev/null && adduser vos_login "$_g" >/dev/null 2>&1 || true
done
install -d -m 0755 -o vos_login -g vos_login /var/lib/vos_login 2>/dev/null || true
install -d -m 0755 /var/lib/vitruvian 2>/dev/null || true
# Greeter mode is opt-in: `touch /var/lib/vitruvian/greeter-enabled` and
# reboot to switch from autologin to the graphical greeter. The vitruvio
# chain services skip themselves while the sentinel is present; janus
# spawns app_server + vitruvian-login instead.
