[Unit]
Description=Vitruvian Janus - privileged server launcher and launch daemon
DefaultDependencies=no
Before=graphical.target

[Service]
Type=simple
ExecStartPre=-/bin/mkdir -p /run/vitruvian
ExecStart=/system/servers/janus
Restart=on-failure
RestartSec=1s
StandardOutput=append:/var/log/janus.log
StandardError=append:/var/log/janus.log
User=root
Group=root

[Install]
WantedBy=sysinit.target
