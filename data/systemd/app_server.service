[Unit]
Description=Vitruvian app_server (display server)
Conflicts=getty@tty1.service
After=janus.service registrar.service
Requires=janus.service registrar.service

[Service]
Type=forking
PIDFile=/run/vitruvian/app_server.pid
ExecStart=/system/servers/janus_launch app_server
StandardOutput=append:/var/log/appserver.log
StandardError=append:/var/log/appserver.log
Restart=no

[Install]
WantedBy=graphical.target
