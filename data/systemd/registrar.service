[Unit]
Description=Vitruvian registrar (app roster)
ConditionPathExists=!/var/lib/vos/greeter-enabled
After=janus.service
Requires=janus.service

[Service]
Type=forking
PIDFile=/run/vos/registrar.pid
ExecStart=/system/servers/janus_launch registrar
StandardOutput=append:/var/log/registrar.log
StandardError=append:/var/log/registrar.log
Restart=no

[Install]
WantedBy=graphical.target
