[Unit]
ConditionPathExists=!/var/lib/vos/greeter-enabled
Description=Vitruvian notification_server
After=janus.service app_server.service
Requires=janus.service app_server.service

[Service]
Type=forking
PIDFile=/run/vos/notification_server.pid
ExecStart=/system/servers/janus_launch notification_server
StandardOutput=append:/var/log/notification_server.log
StandardError=append:/var/log/notification_server.log
Restart=no

[Install]
WantedBy=graphical.target
